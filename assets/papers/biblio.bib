@article{Henry_George_Maquera_Quispe_2019,
 abstract = {El trabajo de investigacion se baso en el analisis del cambio organizacional bajo la implementacion del marco de trabajo de Cobit, para garantizar el correcto uso de los activos de tecnologias de informacion. La investigacion se llevo a cabo en organizaciones publicas y privadas de la region central del Peru. Se conto con la participacion del personal asignado en las areas de tecnologias de informacion, que permitieron el acceso a informacion respecto a los procesos y servicios de tecnologias de informacion de las organizaciones bajo estudio. El metodo utilizado fue el analitico debido a que se observo causas y efectos partiendo de los principios de las buenas practicas de Cobit. La investigacion permitio establecer que existe una directa y solida correlacion entre la percepcion de los trabajadores y el uso del marco de trabajo de Cobit. Los resultados indicaron que la participacion de buenas practicas de ITIL permitieron una mejor integracion de los activos de TI en el adecuado desarrollo del marco de trabajo de Cobit. Sin embargo, se aprecio una diferenciada evolucion entre las organizaciones publicas y privadas, mayormente, debido a factores internos como la cultura organizacional existente.},
 annote = {Insights: The paper's title matches your query, but it doesn't address your specific question. || 
Conclusions: - The research concludes that effective corporate governance requires active participation from organizational personnel, as it is directly linked to knowledge management necessary for implementing the Cobit framework.
- Workers in organizations perceive changes in established processes more significantly in private organizations due to their focus on achieving goals, unlike public organizations where cultural change poses challenges.
- The study highlights that the integration of ITIL best practices has facilitated a quicker integration of IT assets within the Cobit framework, enhancing the management of these assets.
- There is a notable difference in the evolution of Cobit implementation between public and private organizations, with private organizations showing more significant improvements.
- The research emphasizes that the success of processes is closely related to the efficiency and effectiveness of the information generated, underscoring the importance of good governance practices in elevating service levels in organizations. || 
Results: - Organizations private experienced an average increase of 31% in their capacity after implementing the Cobit framework.
- Organizations public saw a 27% increase in capacity, although their initial level of service was rated as level 1.
- The initial average service level for public organizations was 9, indicating minimal compliance with IT service standards.
- The research highlighted a slower improvement in public organizations compared to private ones, attributed to internal factors like organizational culture.
- The study established a strong correlation between employee perception and the effective use of the Cobit framework. || 
Objectives: - The primary objective of the research is to analyze organizational change under the implementation of the Cobit framework to ensure the proper use of information technology assets.
- The research aims to evaluate the perception of employees regarding the improvements achieved through the Cobit framework in public and private organizations.
- It seeks to establish a correlation between employee perception and the use of the Cobit framework.
- The study intends to assess the integration of ITIL best practices to enhance the management of IT assets within the Cobit framework.
- The research also aims to diagnose the state of IT services and evaluate the evolution of Cobit usage in organizations. },
 authors = {Henry George Maquera Quispe and Marjorie Gabriela del Carmen Delgado Rospigliosi and María Elena Tasa Catanzaro},
 doi = {10.33326/26176033.2019.25.863},
 number = {25},
 pages = {41-52},
 publication_type = {article},
 title = {Marco de trabajo de Cobit para en el adecuado uso de tecnologías de información en organizaciones públicas y privadas},
 year = {2019}
}

@article{Heru_Nugroho_2016,
 abstract = {The existence of the enterprise architecture is an attempt of managing and planning over the evolution of information systems in the sphere of an enterprise with model-based. In developing the enterprise architecture, there are several tools definition of components in the system. This tool is known as enterprises architecture (EA) framework. In this paper, we present a method to build a model of enterprise architecture in accordance with the needs of the Organization by Understanding the characteristics of the EA framework such as Zachman, TOGAF, and FEAF. They are selected as the EA framework will be used to determine the characteristics of an EA because the framework is most widely used in corporate or Government. In COBIT 5 framework, there is a process associated with enterprise architecture it is APO03 Manage Enterprise Architecture. At this stage of the research, we describe the link between the characteristics of the EA with one process in COBIT 5 framework. The results contribute to give a recommendation how to design EA for organization based on the characteristic of EA in Context Enterprise Governance using COBIT 5 Framework.},
 annote = {Insights: The paper focuses on COBIT 5 and its integration with enterprise architecture frameworks like TOGAF, but does not specifically address aligning COBIT, TOGAF, ITIL, and NIST CSF for multivariate architecture models involving IA, Blockchain, and Open Data. || 
Conclusions: - The authors conclude that understanding the characteristics of enterprise architecture frameworks such as Zachman, TOGAF, and FEAF is essential for organizations to develop effective models of enterprise architecture.
- They highlight that the development of enterprise architecture requires input from business requirements to achieve desired outcomes, including various models such as business, system, and information models.
- The paper emphasizes the importance of aligning the characteristics of enterprise architecture with the goals, inputs, and processes outlined in the COBIT 5 framework, specifically the APO03 Manage Enterprise Architecture process.
- The authors suggest that mapping the characteristics of different frameworks can guide organizations in implementing enterprise architecture modeling effectively.
- They note that the research contributes recommendations for designing enterprise architecture based on the characteristics identified in the context of enterprise governance using the COBIT 5 framework. || 
Results: - The paper presents a method to build a model of enterprise architecture by exploring the characteristics of the Zachman, TOGAF, and FEAF frameworks.
- It emphasizes that the frameworks are easy to understand and can be mapped to find suitable conditions for organizations.
- The classification within the frameworks allows for the identification of different parts of the IT infrastructure from various perspectives.
- The TOGAF framework is noted to improve efficiency in IT operations, leading to lower costs for development, support, and maintenance.
- It is indicated that using TOGAF can reduce investment risks in the future due to a simpler IT infrastructure. || 
Objectives: - The primary objective of the research is to define the specific research problem and justify the value of a solution regarding enterprise architecture characteristics.
- The research aims to compare the advantages and disadvantages of various enterprise architecture frameworks, specifically Zachman, TOGAF, and FEAF.
- Another objective is to gain insights into the characteristics of enterprise architecture by analyzing different frameworks.
- The research seeks to map the characteristics of enterprise architecture with the process of Manage Enterprise Architecture in the COBIT 5 framework.
- The study aims to provide a guide for implementing enterprise architecture modeling based on the identified patterns from the comparison of multiple frameworks. },
 authors = {Heru Nugroho and Tutut Herawan},
 doi = {10.11591/IJEECS.V3.I1.PP240-248},
 journal = {Indonesian Journal of Electrical Engineering and Computer Science},
 number = {1},
