@article{Fazilat_Hojaji_2012,
 abstract = {SOA governance has a critical role in achieving success and realizing the benefits of SOA. Without effective SOA governance, organizations will experience some significant challenges including difficulties in designing effective decision structures and managing services. To address SOA challenges, organizations require a comprehensive SOA governance framework to implement management and control mechanisms. Study of existing frameworks reveals that these frameworks are not expressive enough to cover all elements of SOA governance and also, they do not completely document underpinning structures such as processes, procedures, responsibilities and measurement metrics. In this paper, we propose a new SOA governance framework that is more comprehensive and expressive than its counterparts. In the process of developing the framework, a set of important elements for a desired SOA governance framework is proposed. Based on these elements, a new SOA governance framework is developed. The proposed framework is obtained by extending characteristics of COBIT and applying ITIL service lifecycle activities to support the SOA governance principles and requirements. It is a perceptible framework that clarifies all processes, activities, metrics and other related elements in a logical structure. Also, to simplify the application of the framework, an implementation process is proposed.},
 annote = {Insights: The paper does not address your specific question. || 
Conclusions: - The authors conclude that effective SOA governance is essential for organizations to overcome significant challenges and realize the benefits of SOA.
- They identify that existing SOA governance frameworks lack comprehensiveness and do not adequately document necessary elements such as processes, procedures, and metrics.
- A new SOA governance framework is proposed, which is more expressive and comprehensive than existing frameworks, incorporating characteristics of COBIT and ITIL service lifecycle activities.
- The proposed framework aims to clarify all processes, activities, metrics, and related elements in a logical structure, facilitating better understanding among stakeholders.
- The authors suggest that the framework can be periodically evaluated for efficiency and effectiveness, providing a basis for future research and improvements in SOA governance practices. || 
Results: - The proposed SOA governance framework is more comprehensive and expressive than existing frameworks.
- It clarifies all processes, activities, metrics, and related elements in a logical structure.
- The framework extends characteristics of COBIT and applies ITIL service lifecycle activities to support SOA governance principles and requirements.
- An implementation process is proposed to simplify the application of the framework.
- ICTIM periodically evaluates the efficiency and effectiveness of the framework by assessing maturity using a process maturity model and identifying gaps. || 
Objectives: - The primary objective of the research paper is to propose a more comprehensive SOA governance framework to address existing shortcomings in current frameworks.
- The research aims to identify and define a structured set of necessary elements that should be included in an effective SOA governance framework.
- The paper seeks to evaluate the proposed framework's applicability and ease of use through feature analysis techniques.
- Another aim is to demonstrate the framework's utility by applying it in a case study within an IT department.
- The research also intends to provide guidance for future actions and improvements related to SOA governance practices. },
 authors = {Fazilat Hojaji and Mohammad Reza Ayatollahzadeh Shirazi},
 doi = {10.5121/IJMIT.2012.4304},
 journal = {International Journal of Managing Information Technology},
 number = {3},
