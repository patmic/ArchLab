@incollection{Karl_D_Schubert_2024,
 abstract = {Abstract With the ever-increasing focus on artificial intelligence and use of nearly infinite information (data) available from an almost infinite number of sources (private, public, and government data bases; the web, etc.), understanding data governance, privacy, and ethics surrounding the availability and use of data is more important than ever. Nearly every day, new data breaches by and effecting individuals and organizations come to light. Nearly every day, new uses for data are envisioned and the ethical considerations around collection, storage, and use of these data are yet to be clearly thought out. The need for data governance to protect privacy and ensuring the ethical use of data is clear and there are many challenges to effectively define and implement effective data governance policies. And these must be implemented through legal and regulatory frameworks to be effective and enforceable. In this chapter, we will examine these topics including the challenges implementing effective data governance policies, the legal and regulatory frameworks governing data privacy and ethics, and a look to the future. },
 annote = {Insights: The paper's title matches your query, but it doesn't address your specific question. || 
Conclusions: - Data breaches have significant impacts on organizations and individuals.
- Data governance, privacy, and ethics are crucial in today's world. || 
Results: - IBM Security studied 550 organizations impacted by data breaches.
- Significant impacts and costs of data breaches were identified. || 
Objectives: - The primary objective of the research paper is to examine the challenges of implementing effective data governance policies.
- The paper aims to explore the legal and regulatory frameworks governing data privacy and ethics.
- It seeks to highlight the importance of understanding data governance, privacy, and ethics in the context of increasing data breaches and the use of artificial intelligence.
- The research intends to define key terms related to data governance, privacy, and ethics to clarify their distinctions.
- Additionally, the paper looks to provide insights into the future of data governance and its implications for organizations. },
 authors = {Karl D. Schubert and David Barrett},
 doi = {10.1007/978-3-031-51063-2_5},
 journal = {Technology, work and globalization},
 pages = {87-110},
 publication_type = {incollection},
 title = {Data Governance, Privacy, and Ethics},
