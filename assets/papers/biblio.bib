@article{Christoph_Moser_2005,
 abstract = {In practice more and more concepts are used for IT service management. Standards like the IT Infrastructure Library (ITIL) ensure that IT services are delivered to meet all requirements of the business processes. They permit the effective and efficient design, operation and maintenance of IT services and the underlying service components in the short run. However, cost savings through the planning and controlling of the IT architecture remain unattended. This shortcoming can be eliminated with the integration of IT architecture management and IT service management frameworks into a superior IT governance framework. Since ITIL is one of the most established standards for IT service management it is used as the starting point to align IT service and architecture management.},
 annote = {Insights: The paper does not address the specific alignment of COBIT, TOGAF, ITIL, and NIST CSF for implementing a multivariate architecture model with IA, Blockchain, and Open Data within a legal governance framework. || 
Conclusions: - Integration of IT architecture management and IT service management frameworks is necessary for effective IT governance.
- The service catalogue is used to model as-is and target architectures of single services and the corresponding IT architecture. || 
Results: - The integration of IT architecture management and IT service management frameworks can lead to significant cost savings in IT service provision.
- The expanded service catalogue concept supports the identification of existing or planned services that meet business requirements.
- The service catalogue facilitates a standardized vocabulary for service description, enhancing communication within IT organizations and with customers.
- The paper highlights the need for a comprehensive service catalogue that includes financial management mechanisms to manage costs effectively.
- It emphasizes the importance of aligning architecture management with ITIL processes to improve long-term operation and maintenance of IT services. || 
Objectives: - The primary objective of the paper is to integrate IT architecture management with IT service management to enhance IT governance frameworks.
- The paper aims to analyze ITIL best practices in relation to their contribution to IT architecture management.
- It seeks to expand the concept of the service catalogue to support architecture management more comprehensively.
- The research intends to identify possible integration points for IT architecture management within existing frameworks.
- It aims to provide insights into the financial management mechanisms related to IT service provision through the service catalogue. },
 authors = {Christoph Moser and Franz Bayer},
 journal = {Emisa Forum},
 pages = {137-151},
 publication_type = {article},
 title = {IT architecture management: A framework for IT-services},
 tmpurl = {https://subs.emis.de/LNI/Proceedings/Proceedings75/GI-Proceedings.75-10.pdf},
 year = {2005}
},

