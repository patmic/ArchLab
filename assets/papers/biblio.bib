@inproceedings{Andreas_Schmitz_2022,
 abstract = {Digitalization of public services, particularly in cross-border contexts, demands for a high level of interoperability. To effectively and systematically cater for interoperability in public service design, architecture development methodologies represent important means of support. The Design Science Research Methodology (DSRM) or the The Open Group Architecture Framework (TOGAF) Architecture Development Method (ADM) provide great tools for rigorously developing digital public services and service architectures. However, these approaches do not per se sufficiently address interoperability. This paper proposes a methodical framework based on DSRM and TOGAF to develop public service architectures, which tackles all layers of interoperability of the European Interoperability Framework (EIF). The proposed framework is tested on the use-case of small-scale public procurement services and on PEPPOL standard specifications. The framework comprises six phases, covering the four layers of interoperability and the TOGAF viewpoints while enabling an iterative design process, which is inspired by DSRM.},
 annote = {Insights: The paper does not address the alignment of COBIT, TOGAF, ITIL, and NIST CSF for implementing a multivariate architecture model with IA, Blockchain, and Open Data within a legal governance framework. || 
Conclusions: - Methodical framework for developing public service architectures
- Further research needed on small-scale procurement and cross-border interoperability for SMEs || 
Results: - The framework proposed in the paper includes six phases that address all layers of interoperability as defined by the European Interoperability Framework (EIF).
- Phase 6 distinguishes between creating a solution architecture or a reference architecture, with specific processes for each.
- The development of a reference architecture follows the communication phase of the Design Science Research Methodology (DSRM) and contributes to a knowledge base for further research.
- The reference architecture serves as a baseline for developing more concrete solution architectures, which are implemented in phase 6b.
- Phase 6b involves necessary steps for implementing and migrating a concrete solution architecture, aligning with existing methodologies like the TOGAF ADM phases E-H. || 
Objectives: - The primary objective of the paper is to propose a methodical framework for developing public service architectures that ensure interoperability in digital public services.
- The framework aims to address all layers of interoperability as outlined in the European Interoperability Framework (EIF).
- The paper seeks to exemplify the proposed framework through a use case focused on small-scale public procurement services in Germany.
- It aims to simplify the specification of interoperability standards for public services, drawing on existing methodologies and standards.
- Further research objectives include evaluating the framework's effectiveness in ensuring cross-border interoperability for small and medium-sized enterprises (SMEs). },
 author = {Andreas Schmitz and Ansgar Mondorf and Maria A. Wimmer},
 title = {Framework for designing interoperable public service architectures with exemplification along small-scale procurement and PEPPOL},
 conference_series = {Digital Government Research},
 publication_type = {inproceedings},
 year = {2022},
 tmpurl = {https://dl.acm.org/doi/pdf/10.1145/3543434.3543473},
 tmpdoi = {10.1145/3543434.3543473}
},

