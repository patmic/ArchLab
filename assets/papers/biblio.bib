@article{Soukaina_Elhasnaoui_2014,
 abstract = {This paper presents a multi-agents architecture which facilitates the integration of three major IT governance frameworks: COBIT5, ITIL V3 and ISO/IEC27002, to optimize the construction of a distributed system. This architecture proposes a new and easier method to develop a distributed multi agents system, where agents involved in this system can communicate in a distributed way thanks to functionalities offered by the system. It gives finally an overview of implementation of a prototype of the proposed solution limited for the moment to integration of processes most used in the majority of information systems.},
 annote = {Insights: The paper focuses on integrating COBIT 5, ITIL V3, and ISO/IEC 27002 within a multi-agent system architecture for IT governance, emphasizing cooperation among agents to optimize processes, but does not specifically address TOGAF or NIST CSF alignment. || 
Conclusions: - Proposed architecture integrates COBIT 5, ITIL V3, and ISOIEC 27002.  
- Intelligent agents enhance communication and cooperation for IT governance. || 
Results: - Proposed multi-agent architecture integrates COBIT5, ITIL V3, ISO/IEC27002.
- Prototype implementation focuses on common information system processes. || 
Objectives: - Integrate COBIT5, ITIL V3, and ISO/IEC27002 frameworks.  
- Optimize construction of a distributed multi-agent system. },
 author = {S. Elhasnaoui and H. Medroni and S.Faris and H.Iguer and A. Sayouti},
 title = {Designing a Multi Agent System Architecture for IT Governance Platform},
 doi = {10.14569/IJACSA.2014.050524},
 journal = {International Journal of Advanced Computer Science and Applications},
 publication_type = {article},
 tmppublisher = {The Science and Information Organization},
 volume = {5},
 number = {5},
 year = {2014}
 tmpurl = {http://dx.doi.org/10.14569/IJACSA.2014.050524},
 tmpurl = {https://thesai.org/Downloads/Volume5No5/Paper_24-Designing_a_Multi_Agent_System_Architecture_for_IT_Governance_Platform.pdf},
}

@article{T_I_Fajri_2024,
 abstract = {This study examines the measurement of Information Technology governance and management capability levels using Cobit 5.0. Researchers collected data through questionnaires and interviews. Data processing from questionnaires and interviews can reveal the company's current level. In the EDM domain, the company scored very high in the process that addresses information technology risk optimization. Regular evaluation of business processes is crucial to create alignment and deal with possible risks. To move up to level two, companies must identify and understand the impact of the risks that arise. Companies should enhance their information technology services and security within the domain, perform audits, and report current and future risks. In this domain, companies must identify service capacity, predict future needs, and be ready to face sudden changes. In the DSS domain, companies need to have information system analysis experts conduct training for their staff, identify availability and service problems, and test the ability of their systems to move up to level two.},
 annote = {Insights: The paper's title matches your query, but it doesn't address your specific question. || 
Conclusions: - Company scored high in IT risk optimization process.
- Recommendations include improving IT services, security, and risk reporting. || 
Results: - Company scored low in IT risk management processes.  
- Regular evaluations needed to improve IT governance and alignment. || 
Objectives: - The primary objective of the research is to measure the capability levels of Information Technology governance and management processes using the Cobit 5.0 framework.
- The study aims to evaluate how well companies align their information systems with their needs and requirements.
- It seeks to identify areas for improvement in information technology services and security within organizations.
- The research intends to provide insights into managing and optimizing information technology risks effectively.
- Additionally, the study aims to enhance the decision-making process by providing relevant and accurate information for planning and operating a company. },
 author= {T. I. Fajri and Uli Wildan Nuryanto and Muazziss Najmi and Dikky Suryadi and Cut Susan Octiva},
 title = {The Application of Cobit 5.0 Framework to Measure Capability of Information and Technology Governance and Management Processes},
 journal = {Jurnal Informasi dan Teknologi},
 year = {2024},
 publication_type = {article}
 tmpurl = {https://jidt.org/jidt/article/download/515/323},
 tmpdoi = {10.60083/jidt.v6i1.515},
}

@inproceedings{Tim_Huygh_2018,
 abstract = {Drawing on the COBIT 5 framework, this research presents the results of an analysis into which governance and management of IT processes are leveraged in practice for answering two key global IT management concerns: alignment and security. For practice, this research specifically sheds light on which governance and management of IT processes appear to be most important for explaining the achievement of alignment and security. Practitioners can therefore use these results as a benchmark to answer these concerns.},
 annote = {Insights: The paper's title matches your query, but it doesn't address your specific question. || 
Conclusions: - COBIT 5 framework can be used to address alignment and security concerns in IT management.
- Certain governance and management processes are important for achieving alignment and security. || 
Results: - The paper identifies governance and management of IT processes that are important for achieving alignment and security.
- The results can be used as a benchmark for organizations concerned with alignment and security. || 
Objectives: - The primary research objective is to identify which governance and management of IT processes are most important for achieving alignment and security objectives in practice.
- The research aims to analyze the effectiveness of these processes in addressing key global IT management concerns.
- It seeks to provide practitioners with benchmark results that can be used to enhance alignment and security within their organizations.
- The study employs a penalized regression approach (lasso estimation) to achieve its objectives.
- The research also aims to introduce a conceptual model that underpins the inquiry into alignment and security in IT governance. },
 author = {Tim Huygh and Steven De Haes and Anant Joshi and Wim Van Grembergen},
 title = {Answering Key Global IT Management Concerns Through IT Governance and Management Processes: A COBIT 5 View},
 year = {2018},
 pages = {5335-5344}
 %conference_series = {Hawaii International Conference on System Sciences},
 %publication_type = {inproceedings},
 tmpdoi = {10.24251/HICSS.2018.665},
 tmpurl = {https://scholarspace.manoa.hawaii.edu/bitstream/10125/50554/1/paper0667.pdf},
}

@article{Tri_Susilowati_2023,
 abstract = {Building an information system in Sri Purnomo village requires IT governance from planning to implementation, so as to produce an organization that is able to achieve its goals optimally. Especially for village governments who want to run good-governance. Payroll operations and attendance attendance are currently done manually so that it slows down payroll calculations. Therefore it is necessary to collect data on the status of attendance, easy to find, and accessible to interested parties at any time, so that payment of salaries given to village officials is in accordance with applicable regulations. The Open This research focuses on the goal of designing an enterprise architecture in the form of a blueprint which includes business architecture, data architecture and application architecture to support Sri Purnomo Village information systems, especially attendance and payroll information systems. The Group Architecture Framework (TOGAF) offers a comprehensive method for managing, creating, and practicing existing business information architecture in the village. The use of Enterprise Architecture in the village of Sri Purnomo provides a clear picture of the system to be developed in the future and system integration. },
 annote = {Insights: The paper's title matches your query, but it doesn't address your specific question. || 
Conclusions: - The authors conclude that implementing an information system for attendance and payroll in Sri Purnomo Village is essential for improving efficiency and accuracy in these processes.
- They emphasize the importance of IT governance in achieving optimal organizational goals, particularly for village governments aiming for good governance.
- The research highlights the necessity of a structured enterprise architecture, including business, data, and application architecture, to support the information systems.
- The use of the TOGAF framework is deemed beneficial for managing and integrating the information architecture within the village.
- The authors assert that a well-designed information system will enhance service delivery and provide better access to information for stakeholders in the village. || 
Results: - The research identifies the need for IT governance in Sri Purnomo village to enhance organizational effectiveness and achieve optimal goals.
- It highlights the current manual processes for payroll and attendance, which slow down payroll calculations.
- The study emphasizes the importance of designing an enterprise architecture blueprint, including business, data, and application architecture, to support the information systems.
- The application of the TOGAF framework is proposed as a comprehensive method for managing and implementing the enterprise architecture.
- The research aims to provide a clear picture of future system development and integration for the village's information systems. || 
Objectives: - The primary objective of the research is to design an enterprise architecture blueprint for the information systems in Sri Purnomo Village, focusing on attendance and payroll systems.
- The research aims to implement IT governance from planning to execution to enhance organizational effectiveness in achieving its goals.
- It seeks to address the current manual processes of payroll and attendance, which hinder timely salary calculations.
- The study intends to create a comprehensive framework that includes business architecture, data architecture, and application architecture.
- It aims to provide a clear vision for future system development and integration within the village's information systems. },
 authors = {Tri Susilowati and Sucipto Sucipto and Widianto Widianto and Meliana Dewi},
 doi = {10.47233/jteksis.v5i3.824},
 journal = {Jurnal Teknologi Dan Sistem Informasi Bisnis},
 number = {3},
 pages = {234-241},
 publication_type = {article},
 title = {Penerapan Togaf Adm Pada Arsitektur Sistem Informasi Absensi Dan Penggajian Di Desa Sri Purnomo},
 url = {https://jurnal.unidha.ac.id/index.php/jteksis/article/download/824/557},
 volume = {5},
 year = {2023}
}
